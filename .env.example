# Copy to .env.local and fill in. Do not put real secrets or production URLs in this file when committing.

# WPGraphQL HTTP endpoint: must be the exact URL from WP Admin → GraphQL → Settings (ends with /graphql).
# The client POSTs JSON like: { "query": "...", "variables": { ... } } with only Content-Type: application/json.
NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://example.com/your-wp-folder/graphql

# Legacy alias if you do not set NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL:
# WORDPRESS_GRAPHQL_URL=https://example.com/your-wp-folder/graphql

# WordPress site home (install folder), no /graphql. Used for Origin/Referer and fallback roots.
WORDPRESS_URL=https://example.com/your-wp-folder

# Exposed to the browser for direct Contact Form 7 submissions (CF7 REST feedback).
NEXT_PUBLIC_WORDPRESS_URL=https://example.com/your-wp-folder

# If WordPress is in a subdirectory of that host but you prefer a short WORDPRESS_URL, add the folder slug:
# WORDPRESS_HOME_PATH=mywp
# (tries https://your-host/mywp/graphql and …/index.php/graphql in addition to other roots)

# Optional: when GraphQL URL is https://host/graphql but WP lives under extra paths, extend auto-tries (comma-separated):
# WORDPRESS_GRAPHQL_PATH_PREFIXES=mainevent,customfolder

# Local dev only: "unable to get local issuer certificate" — stop dev server after changing, then npm run dev
# WORDPRESS_GRAPHQL_INSECURE_TLS=1

# Optional: override hero background (full URL)
NEXT_PUBLIC_HERO_BACKGROUND_URL=

# Contact Form 7
CF7_FORM_ID=
CF7_FIELD_NAME=your-name
CF7_FIELD_EMAIL=your-email
CF7_FIELD_MESSAGE=your-message

# CF7 identifiers for direct browser REST submission
# _wpcf7_unit_tag = the 7-char unit tag from your CF7 shortcode (or from your CF7 form HTML)
NEXT_PUBLIC_CF7_UNIT_TAG=26948cd
# contact-forms/{id}/feedback expects numeric WP form post ID (seen in the REST route when it works)
NEXT_PUBLIC_CF7_FORM_POST_ID=211

ARTISTS_GRAPHQL_CATEGORY=Artist
ARTISTS_CATEGORY_SLUG=artist

# --- Netlify (production) ---
# Netlify never reads .env.local. Copy these keys into:
# Site settings → Environment variables, then trigger a new deploy.
# NEXT_PUBLIC_* values are embedded at `next build` time — add them before build.
